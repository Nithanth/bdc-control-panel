# =====================================================
# BDC Control Panel — Environment Variables Template
# Copy to .env.local and fill in. NEVER commit .env.local
# =====================================================

# ---- Supabase Cloud ----
# Get these from: supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...                  # safe to expose to browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...                      # SERVER ONLY — never expose

# ---- Square ----
# Use SANDBOX credentials during development. Switch to production only at cutover.
SQUARE_ENVIRONMENT=sandbox                            # sandbox | production
SQUARE_ACCESS_TOKEN=EAAA...                           # SERVER ONLY
SQUARE_APPLICATION_ID=sandbox-sq0idb-...              # safe to expose to browser
SQUARE_LOCATION_ID=L...                               # your studio location
SQUARE_WEBHOOK_SIGNATURE_KEY=...                      # for verifying webhook authenticity

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ---- Sentry (optional in dev, required in prod) ----
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ---- Admin bootstrap ----
# Email of the first admin user created on initial deploy
INITIAL_ADMIN_EMAIL=owner@bollywooddancecentral.com
